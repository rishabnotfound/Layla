# ---- Database ----
# Local: mongodb://layla:<password>@127.0.0.1:27017/Layla?authSource=admin
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=
MONGODB_DB=Layla

# ---- Auth ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
CODE_PEPPER=

# ---- Web Push (VAPID) ----
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:you@example.com

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ---- Cloudflare Turnstile ----
# https://dash.cloudflare.com → Turnstile → Add site
CF_TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- Queue worker ----
# The Next app POSTs to QUEUE_URL/kick to wake the worker when a send is queued.
# The worker binds to 127.0.0.1:QUEUE_PORT. Same host as Next.
QUEUE_URL=http://127.0.0.1:4001
QUEUE_PORT=4001
QUEUE_CONCURRENCY=250
QUEUE_POLL_MS=1500
QUEUE_PROGRESS_EVERY=25

# ---- Admin panel ----
# ADMIN_PASSWORD_HASH: scrypt hash of your admin password. Generate with:
#   node -e "const c=require('crypto');const p='your-password-here';const s=c.randomBytes(16);const h=c.scryptSync(p,s,64);console.log('scrypt:'+s.toString('hex')+':'+h.toString('hex'))"
# ADMIN_SESSION_SECRET: 32-byte hex, distinct from SESSION_SECRET. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the password itself — only the hash goes here.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=